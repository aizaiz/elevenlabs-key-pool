{
  "name": "@aizaiz/elevenlabs-key-pool",
  "version": "0.1.0",
  "description": "Spread ElevenLabs usage across multiple subscription accounts, handing back a key from an account that still has quota.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "prepublishOnly": "npm run lint && npm run typecheck && npm test && npm run build"
  },
  "keywords": [
    "elevenlabs",
    "api-key",
    "quota",
    "waterfall",
    "credits"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aizaiz/elevenlabs-key-pool.git"
  },
  "bugs": {
    "url": "https://github.com/aizaiz/elevenlabs-key-pool/issues"
  },
  "homepage": "https://github.com/aizaiz/elevenlabs-key-pool#readme",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "eslint": "^9.14.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0",
    "vitest": "^2.1.4"
  }
}
